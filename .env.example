# Copy this file to .env.local for local development, and set the same
# values as Environment Variables in your hosting provider's dashboard
# (e.g. Vercel > Project Settings > Environment Variables) for production.
# Never commit your real .env.local file.

# --- Stripe (server-only secrets — do NOT prefix with NEXT_PUBLIC_) ------
# Dashboard > Developers > API keys. Use a "restricted key" with only
# Checkout Sessions (read) and Subscriptions (read) permissions if you
# want to minimize blast radius; a standard secret key also works.
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx

# Dashboard > Developers > Webhooks > (your endpoint) > Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: link to your Stripe customer portal for the "Manage billing"
# button. Dashboard > Settings > Billing > Customer portal.
NEXT_PUBLIC_STRIPE_PORTAL_URL=

# --- Session signing -------------------------------------------------
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# --- Google Sheets sync (optional but recommended) --------------------
# Google Cloud Console > APIs & Services > Credentials > OAuth client ID
# (type: Web application). Add your deployed domain(s) under "Authorized
# JavaScript origins" (e.g. https://your-app.vercel.app). This value is
# public and safe to ship to the browser.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Google Sheets picker (optional; lets customers browse/pick one of --
# their existing spreadsheets instead of only ever getting an
# app-created one) ------------------------------------------------------
# Google Cloud Console > APIs & Services > Credentials > Create Credentials
# > API key, then APIs & Services > Library > enable "Google Picker API"
# on the same project as the OAuth client above. Also public/safe to ship
# to the browser. Leave blank to skip the picker (sign-in/import still
# work, just against a single app-created sheet).
NEXT_PUBLIC_GOOGLE_API_KEY=

# --- Google Analytics (optional) ---------------------------------------
# Your GA4 "Measurement ID" (Admin > Data Streams > your web stream), looks
# like G-XXXXXXXXXX. Public/safe to ship to the browser like the other
# NEXT_PUBLIC_ vars above. Leave blank to skip Analytics entirely. Even
# when set, the gtag.js script is only ever injected after a customer
# clicks "Accept" on the cookie banner (see GoogleAnalytics.tsx /
# CookieConsentBanner.tsx) — declining, or not answering yet, means it
# never loads.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Barcode product lookup (optional) --------------------------------
# Leave blank to use UPCitemdb's free trial endpoint (rate-limited, no
# key). Set this to your own lookup service's base URL to use a paid
# provider instead; it must accept ?upc=<code> and return { "name": "..." }.
NEXT_PUBLIC_UPC_LOOKUP_URL=

# --- Support hours (optional — defaults shown) -------------------------
SUPPORT_TIMEZONE=America/Chicago
SUPPORT_START_HOUR=9
SUPPORT_END_HOUR=17

# --- Redis (required for live chat AND the shared barcode database) ----
# Connection string for a Redis instance — the Vercel "Official Redis for
# Vercel" storage integration injects this automatically when connected to
# your project (Storage tab > add a Redis database > Connect to Project).
# Any standard redis:// URL works if you'd rather host your own.
#
# Two features share this one Redis instance: live chat (src/lib/liveChat.ts)
# and the crowdsourced barcode lookup (src/lib/communityLookup.ts + api/
# community-lookup) that lets one customer's manually-entered barcode
# auto-fill for every other customer who scans the same item afterward.
REDIS_URL=

# Discord > Server Settings > Integrations > Webhooks > New Webhook > Copy
# Webhook URL. Posts a one-line notification here whenever a paying
# customer requests a live agent or sends a live-chat message.
DISCORD_WEBHOOK_URL=

# The password for the /owner live-chat inbox (see src/app/owner). Anyone
# with this password can read and reply to live chats, so pick something
# you wouldn't reuse elsewhere, and only share it with people who should
# be answering support chats.
OWNER_DASHBOARD_PASSWORD=

# --- Testing tools (optional — leave unset in production) --------------
# The Account tab's "Simulate paid access" panel (see DevAccessToggle.tsx)
# and its /api/dev/toggle-access route already work automatically under
# `npm run dev` — you don't need this variable for that. Only set this to
# "true" if you specifically want the same panel to appear in a
# production-style local build (`next build && next start`). Never set
# this in your actual deployment's environment variables.
NEXT_PUBLIC_ENABLE_TEST_TOOLS=
